{
  "name": "aqualeap",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "AquaLeap — personal site of 王子健 (Logikinet)",
  "scripts": {
    "dev": "astro dev",
    "studio": "node scripts/studio.mjs",
    "studio:api": "node scripts/content-server.mjs",
    "content:migrate": "tsx scripts/migrate-resources-to-content.ts",
    "sync:projects": "node scripts/sync-projects.mjs",
    "sync:aof": "node scripts/sync-ai-output-formatter.mjs",
    "install:notify": "node scripts/install-notify-workflows.mjs",
    "build": "npm run sync:projects && astro check && astro build && pagefind --site dist",
    "build:ci": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "check": "astro check"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.4.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.8",
    "astro": "^5.9.0",
    "pagefind": "^1.3.0",
    "preline": "^4.2.0",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "tsx": "^4.23.1"
  }
}
