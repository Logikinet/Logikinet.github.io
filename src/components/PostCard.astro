---
import type { BlogPost } from "@/utils/blog";
import { formatDate, getReadingTime } from "@/utils/blog";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const minutes = getReadingTime(post.body ?? "");
---

<article class="card card-spotlight">
  <div class="mb-3 flex flex-wrap items-center gap-x-2 gap-y-1.5">
    <time class="card-meta font-mono" datetime={post.data.pubDatetime.toISOString()}>
      {formatDate(post.data.pubDatetime)}
    </time>
    <span class="text-ink-300 dark:text-ink-600" aria-hidden="true">·</span>
    <span class="card-meta">{minutes} 分钟阅读</span>
    <span class="text-ink-300 dark:text-ink-600" aria-hidden="true">·</span>
    <a
      href={`/blog/categories/${encodeURIComponent(post.data.category)}/`}
      class="card-meta font-medium text-aqua-600 no-underline hover:underline dark:text-aqua-400"
    >
      {post.data.category}
    </a>
    {post.data.featured && <span class="chip-accent">精选</span>}
    {post.data.draft && <span class="chip">草稿</span>}
  </div>

  <h3 class="card-title">
    <a href={`/blog/${post.id}/`} class="no-underline after:absolute after:inset-0">
      {post.data.title}
    </a>
  </h3>

  <p class="card-body max-w-3xl">{post.data.description}</p>

  {
    post.data.tags.length > 0 && (
      <div class="relative z-10 mt-4 flex flex-wrap gap-1.5">
        {post.data.tags.map((tag) => (
          <a
            href={`/blog/tags/${encodeURIComponent(tag)}/`}
            class="chip no-underline transition hover:border-aqua-500/40"
          >
            #{tag}
          </a>
        ))}
      </div>
    )
  }
</article>
