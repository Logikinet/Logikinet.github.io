---
import { SITE } from "@/config";

/**
 * 仅引导到公开 GitHub 主页，不自动导入全部仓库，不替代人工作品集。
 */
---

<aside class="card mt-10">
  <p class="label-meta">GitHub · Public only</p>
  <h2 class="mt-2 text-lg font-semibold tracking-tight">公开仓库动态</h2>
  <p class="mt-2 text-sm leading-relaxed text-ink-600 dark:text-ink-300">
    精选与私有条目由 <code class="chip">src/data/projects/catalog.ts</code> 维护；公开仓可通过
    <code class="chip">npm run sync:projects</code> 发现并拉取 README。私有地址不会写进页面。
  </p>
  <div class="mt-5 flex flex-wrap gap-2">
    <a
      href={`${SITE.github}?tab=repositories`}
      class="btn-secondary !py-1.5 text-xs"
      target="_blank"
      rel="noopener noreferrer"
    >
      查看 @{SITE.githubUser} 公开仓库
    </a>
    <a href={SITE.github} class="btn-ghost !py-1.5 text-xs" target="_blank" rel="noopener noreferrer">
      GitHub 主页
    </a>
  </div>
</aside>
