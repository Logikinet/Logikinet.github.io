---
import {
  type Project,
  getPublicGithubUrl,
  getPublicGiteeUrl,
  repositoryLabel,
} from "@/data/projects";

interface Props {
  project: Project;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const githubUrl = getPublicGithubUrl(project);
const giteeUrl = getPublicGiteeUrl(project);
const repoLabel = repositoryLabel(project);
---

<article class="card flex h-full flex-col">
  <div class="mb-3.5 flex flex-wrap items-center gap-2">
    {project.featured && <span class="chip-accent">精选</span>}
    <span class="chip">{project.status}</span>
    <span class="chip">{repoLabel}</span>
    {
      project.year && (
        <span class="card-meta ml-auto font-mono">{project.year}</span>
      )
    }
  </div>

  <h3 class:list={["card-title", compact ? "!text-base" : ""]}>
    <a href={`/projects/${project.id}/`} class="no-underline after:absolute after:inset-0">
      {project.title}
    </a>
  </h3>

  <p class="card-body flex-1">{project.summary}</p>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {project.stack.slice(0, 5).map((tech) => <span class="chip">{tech}</span>)}
  </div>

  <div class="relative z-10 mt-5 flex flex-wrap items-center gap-2 border-t border-ink-100 pt-4 dark:border-ink-800/80">
    <a href={`/projects/${project.id}/`} class="btn-secondary !px-3 !py-1.5 text-xs">
      详情
    </a>
    {
      githubUrl ? (
        <a
          href={githubUrl}
          class="btn-ghost !px-3 !py-1.5 text-xs"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      ) : project.repositoryStatus === "private" ? (
        <span class="px-2 py-1.5 text-xs text-ink-400">私有仓库</span>
      ) : (
        <span class="px-2 py-1.5 text-xs text-ink-400">仓库整理中</span>
      )
    }
    {
      giteeUrl ? (
        <a
          href={giteeUrl}
          class="btn-ghost !px-3 !py-1.5 text-xs"
          target="_blank"
          rel="noopener noreferrer"
        >
          Gitee
        </a>
      ) : null
    }
    {
      project.demo ? (
        <a
          href={project.demo}
          class="btn-ghost !px-3 !py-1.5 text-xs"
          target="_blank"
          rel="noopener noreferrer"
        >
          Demo
        </a>
      ) : null
    }
  </div>
</article>
