---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { resourceWorkflows, type WorkflowCategory } from "@/data/resources";

const categories = [...new Set(resourceWorkflows.map((w) => w.category))] as WorkflowCategory[];
---

<BaseLayout
  title="Workflows / Rules"
  description="AquaLeap 工作流与规则：AGENTS.md、项目约束、发布检查、验收清单与 Harness 规则摘要。"
>
  <div class="container-page section-space">
    <nav class="text-sm text-ink-500 dark:text-ink-400" aria-label="面包屑">
      <a href="/resources/" class="no-underline hover:text-aqua-600 dark:hover:text-aqua-300">资源库</a>
      <span class="mx-2 opacity-50">/</span>
      <span>Workflows / Rules</span>
    </nav>
    <h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Workflows / Rules</h1>
    <p class="mt-3 max-w-2xl text-sm text-ink-600 dark:text-ink-300">
      常用流程与规则摘要：AGENTS.md、项目约束、开发流程、安全发布、验收清单、计划实现链、Hooks 与 Harness。
    </p>

    <div class="mt-6 flex flex-wrap gap-2" id="wf-filters" role="group" aria-label="按类型筛选">
      <button type="button" class="chip filter-chip is-active" data-filter="all">全部</button>
      {
        categories.map((c) => (
          <button type="button" class="chip filter-chip" data-filter={c}>
            {c}
          </button>
        ))
      }
    </div>

    <ul class="mt-8 space-y-5">
      {
        resourceWorkflows.map((wf) => (
          <li class="wf-item" data-category={wf.category}>
            <article class="card">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <span class="chip-accent">{wf.category}</span>
                <span class="chip font-mono">v{wf.version}</span>
                <span class="card-meta font-mono">更新 {wf.updated}</span>
              </div>
              <h2 class="card-title !text-lg">{wf.title}</h2>
              <p class="card-body">{wf.summary}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {wf.tags.map((t) => (
                  <span class="chip">#{t}</span>
                ))}
              </div>
              <div class="mt-4 flex flex-wrap gap-2">
                <button type="button" class="btn-secondary !py-1.5 text-xs copy-btn" data-copy={wf.body}>
                  一键复制
                </button>
                <button
                  type="button"
                  class="btn-ghost !py-1.5 text-xs toggle-btn"
                  aria-expanded="false"
                  data-target={`wf-${wf.id}`}
                >
                  展开全文
                </button>
              </div>
              <pre
                id={`wf-${wf.id}`}
                class="mt-4 hidden overflow-x-auto rounded-xl border border-ink-200 bg-ink-50/80 p-4 font-mono text-[12px] leading-relaxed text-ink-700 dark:border-ink-700 dark:bg-ink-950/50 dark:text-ink-200"
              >{wf.body}</pre>
              <p class="copy-status mt-2 text-xs text-ink-500" role="status"></p>
            </article>
          </li>
        ))
      }
    </ul>
  </div>

  <script>
    const chips = document.querySelectorAll<HTMLButtonElement>("#wf-filters .filter-chip");
    const items = document.querySelectorAll<HTMLElement>(".wf-item");

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const key = chip.dataset.filter ?? "all";
        chips.forEach((c) => c.classList.toggle("is-active", c === chip));
        items.forEach((el) => {
          el.classList.toggle("hidden", key !== "all" && el.dataset.category !== key);
        });
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".toggle-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const pre = document.getElementById(btn.dataset.target ?? "");
        if (!pre) return;
        const open = pre.classList.toggle("hidden") === false;
        btn.setAttribute("aria-expanded", String(open));
        btn.textContent = open ? "收起全文" : "展开全文";
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const status = btn.closest("article")?.querySelector(".copy-status");
        try {
          await navigator.clipboard.writeText(btn.dataset.copy ?? "");
          if (status) status.textContent = "已复制到剪贴板。";
          btn.textContent = "已复制";
          setTimeout(() => {
            btn.textContent = "一键复制";
          }, 1500);
        } catch {
          if (status) status.textContent = "复制失败，请展开后手动选择。";
        }
      });
    });
  </script>

  <style>
    .filter-chip {
      cursor: pointer;
    }
    .filter-chip.is-active {
      border-color: color-mix(in oklab, var(--color-aqua-500) 45%, transparent);
      background: color-mix(in oklab, var(--color-aqua-500) 12%, transparent);
      color: var(--color-aqua-700);
    }
    :global(html.dark) .filter-chip.is-active {
      color: var(--color-aqua-300);
    }
  </style>
</BaseLayout>
