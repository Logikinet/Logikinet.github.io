---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects, type Project } from "@/data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<BaseLayout title={project.title} description={project.summary}>
  <article class="container-page section-space">
    <p class="label-meta">Project</p>
    <div class="mt-3 flex flex-wrap items-center gap-2">
      {project.featured && <span class="chip border-aqua-500/30 bg-aqua-500/10 text-aqua-700 dark:text-aqua-300">精选</span>}
      <span class="chip">{project.status}</span>
      {project.year && <span class="text-sm text-ink-500">{project.year}</span>}
    </div>
    <h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">{project.title}</h1>
    <p class="mt-4 max-w-3xl text-base leading-relaxed text-ink-600 dark:text-ink-300">{project.summary}</p>

    <div class="mt-8 flex flex-wrap gap-3">
      {
        project.github ? (
          <a href={project.github} class="btn-primary" target="_blank" rel="noopener noreferrer">GitHub</a>
        ) : (
          <span class="btn-secondary opacity-70">GitHub 整理中</span>
        )
      }
      {
        project.demo ? (
          <a href={project.demo} class="btn-secondary" target="_blank" rel="noopener noreferrer">打开 Demo</a>
        ) : (
          <span class="btn-ghost opacity-70">Demo 整理中</span>
        )
      }
      <a href="/projects/" class="btn-ghost">返回列表</a>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      <section class="card lg:col-span-2">
        <h2 class="text-xl font-semibold">项目说明</h2>
        <p class="mt-4 text-sm leading-relaxed text-ink-600 dark:text-ink-300">{project.description}</p>
      </section>
      <section class="card">
        <h2 class="text-lg font-semibold">技术栈</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {project.stack.map((tech) => <span class="chip">{tech}</span>)}
        </div>
        <h3 class="mt-6 text-sm font-medium text-ink-500">状态</h3>
        <p class="mt-1 text-sm text-ink-800 dark:text-ink-100">{project.status}</p>
      </section>
    </div>
  </article>
</BaseLayout>
