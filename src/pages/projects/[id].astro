---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getListedProjects,
  getPublicGithubUrl,
  getPublicGiteeUrl,
  repositoryLabel,
  type Project,
} from "@/data/projects";

export function getStaticPaths() {
  return getListedProjects().map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const githubUrl = getPublicGithubUrl(project);
const giteeUrl = getPublicGiteeUrl(project);
const repoLabel = repositoryLabel(project);
---

<BaseLayout title={project.title} description={project.summary}>
  <article class="container-page section-space">
    <p class="label-meta">Project</p>
    <div class="mt-3 flex flex-wrap items-center gap-2">
      {project.featured && <span class="chip-accent">精选</span>}
      <span class="chip">{project.status}</span>
      <span class="chip">{repoLabel}</span>
      {project.year && <span class="text-sm text-ink-500">{project.year}</span>}
    </div>
    <h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">{project.title}</h1>
    <p class="mt-4 max-w-3xl text-base leading-relaxed text-ink-600 dark:text-ink-300">{project.summary}</p>

    <div class="mt-8 flex flex-wrap gap-3">
      {
        githubUrl ? (
          <a href={githubUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
        ) : project.repositoryStatus === "private" ? (
          <span class="btn-secondary opacity-80">私有仓库 · 地址不公开</span>
        ) : (
          <span class="btn-secondary opacity-70">仓库整理中</span>
        )
      }
      {
        giteeUrl ? (
          <a href={giteeUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
            Gitee
          </a>
        ) : null
      }
      {
        project.demo ? (
          <a href={project.demo} class="btn-secondary" target="_blank" rel="noopener noreferrer">
            打开 Demo
          </a>
        ) : (
          <span class="btn-ghost opacity-70">Demo 整理中</span>
        )
      }
      <a href="/projects/" class="btn-ghost">返回列表</a>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      <section class="card lg:col-span-2">
        <h2 class="text-xl font-semibold">项目说明</h2>
        <p class="mt-4 text-sm leading-relaxed text-ink-600 dark:text-ink-300 whitespace-pre-line">
          {project.description}
        </p>
      </section>
      <section class="card">
        <h2 class="text-lg font-semibold">元信息</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {project.stack.map((tech) => <span class="chip">{tech}</span>)}
        </div>
        <dl class="mt-6 space-y-3 text-sm">
          <div>
            <dt class="text-ink-500">状态</dt>
            <dd class="mt-0.5 text-ink-800 dark:text-ink-100">{project.status}</dd>
          </div>
          <div>
            <dt class="text-ink-500">可见性</dt>
            <dd class="mt-0.5 text-ink-800 dark:text-ink-100">{project.visibility}</dd>
          </div>
          <div>
            <dt class="text-ink-500">仓库</dt>
            <dd class="mt-0.5 text-ink-800 dark:text-ink-100">{repoLabel}</dd>
          </div>
          <div>
            <dt class="text-ink-500">归属</dt>
            <dd class="mt-0.5 text-ink-800 dark:text-ink-100">{project.ownership}</dd>
          </div>
          <div>
            <dt class="text-ink-500">核验</dt>
            <dd class="mt-0.5 text-ink-800 dark:text-ink-100">{project.verificationStatus}</dd>
          </div>
          {
            project.updatedAt && (
              <div>
                <dt class="text-ink-500">更新</dt>
                <dd class="mt-0.5 font-mono text-ink-800 dark:text-ink-100">{project.updatedAt}</dd>
              </div>
            )
          }
        </dl>
      </section>
    </div>
  </article>
</BaseLayout>
