---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { getPublishedPosts, paginate } from "@/utils/blog";

const all = await getPublishedPosts();
const { items, page, totalPages } = paginate(all, 1);
const categories = [...new Set(all.map((p) => p.data.category))];
const tags = [...new Set(all.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="技术博客" description="AquaLeap 技术博客：Agent 工程、Harness、Token 成本、鸿蒙与工程实践。">
  <div class="container-page section-space">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="label-meta">Blog</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">技术博客</h1>
        <p class="mt-3 max-w-2xl text-base text-ink-600 dark:text-ink-300">
          记录可复用的工程判断与实践框架。示例文章提供结构与观点，不伪造实验数据。
        </p>
      </div>
      <a href="/blog/search/" class="btn-secondary">搜索文章</a>
    </div>

    <div class="mt-8 flex flex-wrap gap-2">
      <a href="/blog/categories/" class="chip no-underline hover:border-aqua-500/40">全部分类 ({categories.length})</a>
      <a href="/blog/tags/" class="chip no-underline hover:border-aqua-500/40">全部标签 ({tags.length})</a>
      <a href="/rss.xml" class="chip no-underline hover:border-aqua-500/40">RSS</a>
    </div>

    <div class="mt-10 grid gap-5">
      {items.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination page={page} totalPages={totalPages} basePath="/blog" />
  </div>
</BaseLayout>
