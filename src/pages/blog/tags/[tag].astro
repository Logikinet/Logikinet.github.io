---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getPublishedPosts } from "@/utils/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter((p) => p.data.tags.includes(tag));
---

<BaseLayout title={`标签 · ${tag}`} description={`标签「${tag}」下的文章列表。`}>
  <div class="container-page section-space">
    <p class="label-meta">Tag</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">#{tag}</h1>
    <p class="mt-2 text-sm text-ink-500">{posts.length} 篇文章</p>
    <div class="mt-8 grid gap-5">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
    <a href="/blog/tags/" class="btn-ghost mt-8 inline-flex">全部标签</a>
  </div>
</BaseLayout>
