---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedPosts } from "@/utils/blog";

const posts = await getPublishedPosts();
const tagMap = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) {
    tagMap.set(t, (tagMap.get(t) ?? 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => a[0].localeCompare(b[0], "zh-CN"));
---

<BaseLayout title="标签" description="AquaLeap 博客全部标签。">
  <div class="container-page section-space">
    <p class="label-meta">Tags</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">全部标签</h1>
    <ul class="mt-8 flex flex-wrap gap-3">
      {
        tags.map(([tag, count]) => (
          <li>
            <a href={`/blog/tags/${encodeURIComponent(tag)}/`} class="chip no-underline hover:border-aqua-500/40">
              #{tag} <span class="opacity-60">({count})</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
