---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedPosts } from "@/utils/blog";

const posts = await getPublishedPosts();
const catMap = new Map<string, number>();
for (const p of posts) {
  catMap.set(p.data.category, (catMap.get(p.data.category) ?? 0) + 1);
}
const categories = [...catMap.entries()].sort((a, b) => a[0].localeCompare(b[0], "zh-CN"));
---

<BaseLayout title="分类" description="AquaLeap 博客全部分类。">
  <div class="container-page section-space">
    <p class="label-meta">Categories</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">全部分类</h1>
    <ul class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        categories.map(([category, count]) => (
          <li>
            <a href={`/blog/categories/${encodeURIComponent(category)}/`} class="card block no-underline">
              <p class="font-semibold text-ink-900 dark:text-ink-50">{category}</p>
              <p class="mt-1 text-sm text-ink-500">{count} 篇</p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
