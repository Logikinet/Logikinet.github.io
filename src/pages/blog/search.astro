---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="搜索" description="搜索 AquaLeap 技术博客文章。">
  <div class="container-page section-space max-w-3xl">
    <p class="label-meta">Search</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">搜索文章</h1>
    <p class="mt-3 text-sm text-ink-600 dark:text-ink-300">
      基于 Pagefind 的静态全文搜索。首次构建后可用；本地开发若索引未生成，请先执行生产构建。
    </p>
    <div id="search" class="mt-8"></div>
  </div>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline>
    (function () {
      var el = document.getElementById("search");
      var script = document.createElement("script");
      script.src = "/pagefind/pagefind-ui.js";
      script.onload = function () {
        if (window.PagefindUI) {
          new window.PagefindUI({
            element: "#search",
            showSubResults: true,
            excerptLength: 20,
            resetStyles: false,
          });
        } else if (el) {
          el.innerHTML =
            '<p class="text-sm text-ink-500">搜索组件加载失败。</p>';
        }
      };
      script.onerror = function () {
        if (el) {
          el.innerHTML =
            '<p class="text-sm text-ink-500">搜索索引尚未生成。请运行 <code class="chip">npm run build</code> 后预览，或在部署站点上使用。</p>';
        }
      };
      document.body.appendChild(script);
    })();
  </script>
</BaseLayout>
