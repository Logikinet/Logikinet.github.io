---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { getPublishedPosts, paginate } from "@/utils/blog";
import { SITE } from "@/config";

export async function getStaticPaths() {
  const all = await getPublishedPosts();
  const totalPages = Math.max(1, Math.ceil(all.length / SITE.postsPerPage));
  // page 1 is /blog/ ; generate 2..n
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const pageNum = i + 2;
    return {
      params: { page: String(pageNum) },
      props: { pageNum },
    };
  });
}

interface Props {
  pageNum: number;
}

const { pageNum } = Astro.props;
const all = await getPublishedPosts();
const { items, page, totalPages } = paginate(all, pageNum);
---

<BaseLayout title={`博客 · 第 ${page} 页`} description={`AquaLeap 技术博客第 ${page} 页。`}>
  <div class="container-page section-space">
    <p class="label-meta">Blog</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">技术博客 · 第 {page} 页</h1>
    <div class="mt-10 grid gap-5">
      {items.map((post) => <PostCard post={post} />)}
    </div>
    <Pagination page={page} totalPages={totalPages} basePath="/blog" />
  </div>
</BaseLayout>
