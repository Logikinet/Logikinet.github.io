---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="JSON 格式化工具" description="本地 JSON 格式化、压缩与校验，支持复制与清空，数据不离开浏览器。">
  <div class="container-page section-space max-w-4xl">
    <p class="label-meta">Tool</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">JSON 格式化工具</h1>
    <p class="mt-3 text-sm text-ink-600 dark:text-ink-300">
      格式化、压缩、校验错误。全部在本地完成，不上传数据。
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      <button type="button" id="format-btn" class="btn-primary">格式化</button>
      <button type="button" id="minify-btn" class="btn-secondary">压缩</button>
      <button type="button" id="validate-btn" class="btn-secondary">校验</button>
      <button type="button" id="copy-btn" class="btn-ghost">复制</button>
      <button type="button" id="clear-btn" class="btn-ghost">清空</button>
    </div>

    <label for="json-input" class="mt-6 mb-1.5 block text-sm font-medium">JSON 输入</label>
    <textarea
      id="json-input"
      class="tool-textarea min-h-72"
      spellcheck="false"
      placeholder='{"hello":"aqualeap"}'
    ></textarea>
    <p id="status" class="mt-2 text-sm" role="status" aria-live="polite"></p>
  </div>

  <script>
    const input = document.getElementById("json-input") as HTMLTextAreaElement | null;
    const status = document.getElementById("status");

    function setStatus(msg: string, ok = true) {
      if (!status) return;
      status.textContent = msg;
      status.className = ok
        ? "mt-2 text-sm text-aqua-700 dark:text-aqua-300"
        : "mt-2 text-sm text-red-600 dark:text-red-400";
    }

    function parseJSON() {
      const raw = input?.value ?? "";
      if (!raw.trim()) throw new Error("输入为空");
      return JSON.parse(raw);
    }

    document.getElementById("format-btn")?.addEventListener("click", () => {
      try {
        const data = parseJSON();
        if (input) input.value = JSON.stringify(data, null, 2);
        setStatus("格式化成功");
      } catch (err) {
        setStatus(`格式化失败：${err instanceof Error ? err.message : String(err)}`, false);
      }
    });

    document.getElementById("minify-btn")?.addEventListener("click", () => {
      try {
        const data = parseJSON();
        if (input) input.value = JSON.stringify(data);
        setStatus("压缩成功");
      } catch (err) {
        setStatus(`压缩失败：${err instanceof Error ? err.message : String(err)}`, false);
      }
    });

    document.getElementById("validate-btn")?.addEventListener("click", () => {
      try {
        parseJSON();
        setStatus("校验通过：合法 JSON");
      } catch (err) {
        setStatus(`校验失败：${err instanceof Error ? err.message : String(err)}`, false);
      }
    });

    document.getElementById("copy-btn")?.addEventListener("click", async () => {
      const text = input?.value ?? "";
      if (!text) {
        setStatus("没有可复制的内容", false);
        return;
      }
      try {
        await navigator.clipboard.writeText(text);
        setStatus("已复制到剪贴板");
      } catch {
        setStatus("复制失败，请手动选择文本", false);
      }
    });

    document.getElementById("clear-btn")?.addEventListener("click", () => {
      if (input) input.value = "";
      setStatus("已清空");
    });
  </script>
</BaseLayout>
