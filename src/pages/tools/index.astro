---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { tools } from "@/data/tools";
---

<BaseLayout title="在线工具箱" description="浏览器本地运行的开发小工具：Git Commit 生成、JSON 格式化、文本差异对比。数据不上传。">
  <div class="container-page section-space">
    <p class="label-meta">Tools</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">在线工具箱</h1>
    <p class="mt-4 max-w-2xl text-base text-ink-600 dark:text-ink-300">
      所有工具优先在浏览器本地运行，不上传用户数据。适合日常开发中的轻量处理场景。
    </p>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        tools.map((tool) => (
          <article class="card flex h-full flex-col">
            <div class="flex flex-wrap gap-1.5">
              {tool.tags.map((tag) => (
                <span class="chip">{tag}</span>
              ))}
            </div>
            <h2 class="mt-3 text-xl font-semibold">
              <a href={tool.href} class="no-underline hover:text-aqua-600 dark:hover:text-aqua-300">
                {tool.title}
              </a>
            </h2>
            <p class="mt-2 flex-1 text-sm text-ink-600 dark:text-ink-300">{tool.summary}</p>
            <a href={tool.href} class="btn-primary mt-5 w-fit">打开工具</a>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>
